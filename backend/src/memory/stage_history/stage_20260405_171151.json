[{"query": "\uc774\ub780\uc758 \ub300\ud1b5\ub839\uc774 \ub204\uad6c\uc9c0?", "response": "\ud604\uc7ac \uc774\ub780\uc758 \ub300\ud1b5\ub839\uc740 **\ub9c8\uc218\ub4dc \ud398\uc81c\uc2dc\ud0a4\uc548(Masoud Pezeshkian)**\uc785\ub2c8\ub2e4.\n\n\uadf8\ub294 \uc9c0\ub09c 2024\ub144 5\uc6d4, \ud5ec\uae30 \ucd94\ub77d \uc0ac\uace0\ub85c \uac11\uc791\uc2a4\ub7fd\uac8c \uc0ac\ub9dd\ud55c \uc5d0\ube0c\ub77c\ud798 \ub77c\uc774\uc2dc \uc804 \ub300\ud1b5\ub839\uc758 \ud6c4\uc784\uc744 \ubf51\uae30 \uc704\ud574 \uce58\ub7ec\uc9c4 \uc870\uae30 \ub300\uc120\uc5d0\uc11c \ub2f9\uc120\ub418\uc5b4, 2024\ub144 7\uc6d4\ubd80\ud130 \uacf5\uc2dd\uc801\uc73c\ub85c \ub300\ud1b5\ub839\uc9c1\uc744 \uc218\ud589\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4.\n\n\ud398\uc81c\uc2dc\ud0a4\uc548 \ub300\ud1b5\ub839\uc740 \uc2ec\uc7a5\uc678\uacfc \uc758\uc0ac \ucd9c\uc2e0\uc73c\ub85c, \uc774\ub780\uc758 \uac1c\ud601\ud30c \uc815\uce58\uc778\uc73c\ub85c \ubd84\ub958\ub429\ub2c8\ub2e4. \uadf8\ub294 \ub300\uc120 \uacfc\uc815\uc5d0\uc11c \uad6d\uc81c \uc0ac\ud68c\uc640\uc758 \uad00\uacc4 \uac1c\uc120 \ubc0f \uacbd\uc81c \uc81c\uc7ac \uc644\ud654 \ub4f1\uc744 \uac15\uc870\ud558\uba70 \ubcc0\ud654\ub97c \uc608\uace0\ud55c \ubc14 \uc788\uc2b5\ub2c8\ub2e4.", "timestamp": "2026-04-05T17:11:10.872750"}]
[{"query": "\ubc18\uc11c\ubc29 \ub178\uc120 \ud0c0\ub294 \uc778\uac04\uc774 \ub204\uad6c\ub77c\uace0?", "response": "\ubc18\uc11c\ubc29 \ub178\uc120\uacfc \uc774\ub780\uc758 \uc2e0\uad8c \ud1b5\uce58 \uccb4\uc81c\ub97c \ud655\ub9bd\ud55c \ud575\uc2ec \uc778\ubb3c\uc740 **\ub8e8\ud640\ub77c \ud638\uba54\uc774\ub2c8(Ruhollah Khomeini)**\uc785\ub2c8\ub2e4.\n\n\uadf8\uc640 \uad00\ub828\ud558\uc5ec \uae30\uc5b5\ud574\ub450\uc2dc\uba74 \uc88b\uc740 \uc810\uc740 \ub2e4\uc74c\uacfc \uac19\uc2b5\ub2c8\ub2e4:\n\n*   **\ub8e8\ud640\ub77c \ud638\uba54\uc774\ub2c8:** 1979\ub144 \uc774\ub780 \ud601\uba85\uc744 \uc8fc\ub3c4\ud558\uc5ec \ud314\ub808\ube44 \uc655\uc870\ub97c \ubb34\ub108\ub728\ub9ac\uace0, \uc774\uc2ac\ub78c \uc2e0\uad8c \uc815\uce58 \uccb4\uc81c\uc778 **'\ubca8\ub77c\uc57c\ud14c \ud30c\ud0a4(Velayat-e Faqih, \ubc95\ud559\uc790\uc758 \ud1b5\uce58)'**\ub97c \ub3c4\uc785\ud55c \uc778\ubb3c\uc785\ub2c8\ub2e4. \uc774\ub780\uc758 \ubc18\uc11c\ubc29 \ub178\uc120\uacfc '\uc800\ud56d\uc758 \ucd95'\uc774\ub77c\ub294 \uc0ac\uc0c1\uc801 \ubfcc\ub9ac\ub97c \ub9cc\ub4e0 \uc7a5\ubcf8\uc778\uc785\ub2c8\ub2e4.\n*   **\uc544\uc57c\ud1a8\ub77c \uc54c\ub9ac \ud558\uba54\ub124\uc774:** \ud638\uba54\uc774\ub2c8\uc758 \ub4a4\ub97c \uc774\uc5b4 1989\ub144\ubd80\ud130 \ud604\uc7ac\uae4c\uc9c0 \ucd5c\uace0\uc9c0\ub3c4\uc790 \uc790\ub9ac\uc5d0 \uc788\ub294 \uc778\ubb3c\uc785\ub2c8\ub2e4. \ud638\uba54\uc774\ub2c8\uc758 \ub178\uc120\uc744 \uacc4\uc2b9\ud558\uc5ec **\uac15\uacbd \ubcf4\uc218 \ubc0f \ubc18\uc11c\ubc29\uc8fc\uc758**\ub97c \ucca0\uc800\ud788 \uacac\uc9c0\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4.\n\n\uc989, **\uc0ac\uc0c1\uc801 \ubfcc\ub9ac\ub97c \uc81c\uacf5\ud55c \uc778\ubb3c\uc740 \ub8e8\ud640\ub77c \ud638\uba54\uc774\ub2c8**\uc774\uace0, **\ud604\uc7ac \uadf8 \ub178\uc120\uc744 \uc774\uc5b4\ubc1b\uc544 \uc2e0\uad8c \ud1b5\uce58 \uccb4\uc81c\ub97c \uc218\ud638\ud558\uace0 \uc788\ub294 \uc778\ubb3c\uc740 \uc544\uc57c\ud1a8\ub77c \uc54c\ub9ac \ud558\uba54\ub124\uc774**\ub77c\uace0 \uc774\ud574\ud558\uc2dc\uba74 \ub429\ub2c8\ub2e4.", "timestamp": "2026-04-05T18:05:03.138420"}]
[{"query": "\uc2e0\uad8c \uc815\uce58 \uccb4\uc81c\ub85c \ubcc0\ubaa8\uc2dc\ud0a8 \uc0ac\ub78c\uc774 \ub204\uad6c\ub77c\uace0?", "response": "\uc774\ub780\uc744 \uc2e0\uad8c \uc815\uce58 \uccb4\uc81c\ub85c \ubcc0\ubaa8\uc2dc\ud0a8 \uc778\ubb3c\uc740 **\ub8e8\ud640\ub77c \ud638\uba54\uc774\ub2c8(Ruhollah Khomeini)**\uc785\ub2c8\ub2e4.\n\n\uadf8\uc5d0 \ub300\ud574 \uc870\uae08 \ub354 \uc790\uc138\ud788 \uc124\uba85\ud574 \ub4dc\ub9ac\uc790\uba74 \ub2e4\uc74c\uacfc \uac19\uc2b5\ub2c8\ub2e4:\n\n*   **\uc2e0\uad8c \uc815\uce58\uc758 \uc124\uacc4\uc790:** \uadf8\ub294 **'\ubca8\ub77c\uc57c\ud14c \ud30c\ud0a4(Velayat-e Faqih, \uc774\uc2ac\ub78c \ubc95\ud559\uc790\uc758 \ud1b5\uce58)'**\ub77c\ub294 \ud1b5\uce58 \uc774\ub150\uc744 \ud655\ub9bd\ud588\uc2b5\ub2c8\ub2e4. \uc774\ub294 \uc774\uc2ac\ub78c \ubc95\ud559\uc790\uac00 \uc2e0\uc758 \ub300\ub9ac\uc778\uc73c\ub85c\uc11c \uad6d\uac00\uc758 \ucd5c\uace0 \uad8c\ub825\uc744 \ud589\uc0ac\ud574\uc57c \ud55c\ub2e4\ub294 \uc0ac\uc0c1\uc73c\ub85c, 1979\ub144 \uc774\ub780 \ud601\uba85\uc744 \ud1b5\ud574 \uc774\ub780\uc744 \uc138\uc18d \uc655\uc815\uc5d0\uc11c \uc2e0\uad8c \uc815\uce58 \uccb4\uc81c\ub85c \uc644\uc804\ud788 \ud0c8\ubc14\uafc8\uc2dc\ucf30\uc2b5\ub2c8\ub2e4.\n*   **\ubc18\uc11c\ubc29 \ub178\uc120:** \uadf8\ub294 \uc11c\uad6c\uc758 \uc601\ud5a5\ub825\uc744 \ubc30\uaca9\ud558\uace0 \uc774\uc2ac\ub78c \uac00\uce58\ub97c \ucd5c\uc6b0\uc120\uc73c\ub85c \ud558\ub294 \ubc18\uc11c\ubc29 \ub178\uc120\uc744 \ud655\uace0\ud788 \ud588\uc2b5\ub2c8\ub2e4. \uc774\ub294 \uc624\ub298\ub0a0\uae4c\uc9c0 \uc774\uc5b4\uc9c0\ub294 \uc774\ub780\uc758 \ub300\uc678 \uc815\ucc45\uacfc '\uc800\ud56d\uc758 \ucd95'\uc774\ub77c\ub294 \uc0ac\uc0c1\uc801 \ubfcc\ub9ac\uac00 \ub418\uc5c8\uc2b5\ub2c8\ub2e4.\n*   **\uc2e4\uc6a9\uc801 \uacb0\ub2e8:** \ub9e4\uc6b0 \uac15\uacbd\ud55c \uc885\uad50\uc801 \uc9c0\ub3c4\uc790\uc600\uc9c0\ub9cc, \uc774\ub780-\uc774\ub77c\ud06c \uc804\uc7c1 \ub2f9\uc2dc \uad6d\uac00\uc758 \uc874\ub9bd\uc744 \uc704\ud574 \ud734\uc804\uc744 \ubc1b\uc544\ub4e4\uc774\ub294 \ub4f1 \ub54c\ub85c\ub294 \uc2e4\uc6a9\uc801\uc778 \uacb0\ub2e8\uc744 \ub0b4\ub9ac\uae30\ub3c4 \ud588\ub358 \uc778\ubb3c\uc785\ub2c8\ub2e4.\n\n\ud604\uc7ac \uc774\ub780\uc758 \ucd5c\uace0\uc9c0\ub3c4\uc790\uc778 \uc544\uc57c\ud1a8\ub77c \uc54c\ub9ac \ud558\uba54\ub124\uc774\ub294 \ub8e8\ud640\ub77c \ud638\uba54\uc774\ub2c8\uc758 \ub4a4\ub97c \uc774\uc5b4 \uc774 \uc2e0\uad8c \ud1b5\uce58 \uccb4\uc81c\ub97c \uc218\ud638\ud558\uace0 \uc788\ub294 \uc778\ubb3c\uc785\ub2c8\ub2e4.", "timestamp": "2026-04-05T18:46:01.226732"}]